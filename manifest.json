{
  "manifest_version": 3,
  "name": "No Addict",
  "version": "1.0",
  "description": "Block distracting websites by domain or URL. Toggle rules on and off without deleting them.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["popup.css", "assets/fonts/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
